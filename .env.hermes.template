# ============================================================================
# Hermes Mac — .env template
# Copy to /path/to/hermes-mac/.env and fill in values
# NEVER commit this file. Already in .gitignore.
# ============================================================================

# Telegram bot @dual_hermes_bot
HERMES_TELEGRAM_BOT_TOKEN=<paste token from BotFather>
HERMES_USER_CHAT_ID=750774735
HERMES_BOT_USERNAME=dual_hermes_bot

# Telegram user client (Telethon) — reuse existing credentials
TELEGRAM_API_ID=<from my.telegram.org>
TELEGRAM_API_HASH=<from my.telegram.org>
TELEGRAM_PHONE=<your phone number with +code>

# Local Postgres (Mac)
POSTGRES_DSN=postgresql://hermes:hermes@localhost:5432/hermes

# Hetzner Data API (read-only)
HERMES_DATA_API_URL=https://dualzero.duckdns.org/hermes
HERMES_DATA_API_KEY=<generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))">

# LLM — choose ONE mode:
# Mode A: Hetzner kimi-k2 via Tailscale (recommended start)
LLM_BASE_URL=http://<tailscale-ip-hetzner>:8000/v1
LLM_API_KEY=local-proxy
LLM_MODEL=kimi-k2.5

# Mode B: Ollama local (uncomment if using)
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=nous-hermes2:Q4_K_M

# Mode C: OpenRouter (fallback or critical paths)
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=nousresearch/hermes-4-70b

# ============================================================================
# External APIs (copy from Hetzner .env — read-only keys, safe)
# ============================================================================

# Twitter/X (Sorsa — primary for search)
TWEETSCOUT_API_KEY=<copy from Hetzner .env>

# Brave Search (fallback for X search, limited 2000/mo free)
BRAVE_SEARCH_API_KEY=<copy from Hetzner .env>

# Blockchain RPCs
ALCHEMY_KEY=<copy from Hetzner .env>
ALCHEMY_ETH_URL=<copy from Hetzner .env>
ALCHEMY_WSS=<copy from Hetzner .env>
QUICKNODE_HTTP=<copy from Hetzner .env>
QUICKNODE_WSS=<copy from Hetzner .env>
QUICKNODE_BSC_URL=<copy from Hetzner .env>
QUICKNODE_BSC_WSS=<copy from Hetzner .env>

# Block explorers
ETHERSCAN_API_KEY=<copy from Hetzner .env>
BASESCAN_API_KEY=<copy from Hetzner .env>

# On-chain data
MORALIS_API_KEY=<copy from Hetzner .env>
DEBANK_API_KEY=<copy from Hetzner .env>

# Identity
NEYNAR_API_KEY=<copy from Hetzner .env>

# Optional (if you create accounts)
# KALSHI_EMAIL=
# KALSHI_API_KEY=

# ============================================================================
# Behavior tuning
# ============================================================================

MAX_CONCURRENT_INVESTIGATIONS=15
FAST_PATH_BUDGET_SECONDS=30
ALERTS_PER_DAY_CAP=10

# Solana disabled — ETH + Base only for v1
CHAINS_ENABLED=eth,base

# Logging
LOG_LEVEL=INFO
LOG_FILE=/Users/YOUR_USER/hermes-mac/logs/hermes.log
